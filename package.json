{
  "name": "out-loud",
  "version": "2.0.0",
  "description": "Free, open-source, 100% offline AI text-to-speech desktop app powered by Kokoro-82M.",
  "author": {
    "name": "Julia Kafarska",
    "email": "labs@light-cloud.com",
    "url": "https://out-loud.io"
  },
  "license": "MIT",
  "homepage": "https://github.com/light-cloud-com/out-loud#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/light-cloud-com/out-loud.git"
  },
  "bugs": {
    "url": "https://github.com/light-cloud-com/out-loud/issues"
  },
  "keywords": [
    "tts",
    "text-to-speech",
    "kokoro",
    "tauri",
    "offline",
    "open-source",
    "speechify-alternative"
  ],
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter out-loud-tauri tauri:dev",
    "build": "pnpm --filter out-loud-tauri tauri:build",
    "build:web": "pnpm --filter out-loud-web build",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "release": "node scripts/release.mjs",
    "extension:chrome:pack": "mkdir -p releases/extensions && cd chrome-extension && zip -r ../releases/extensions/out-loud-chrome.zip . -x '*.DS_Store'",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "knip": "5.64.1",
    "lint-staged": "15.5.2",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,vue,json,jsonc}": "oxfmt"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "fsevents",
      "onnxruntime-node",
      "protobufjs",
      "vue-demi"
    ]
  }
}
