{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Out Loud",
  "version": "2.0.0",
  "identifier": "com.lightcloudlabs.outloud",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Out Loud",
        "width": 480,
        "height": 600,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "copyright": "MIT",
    "shortDescription": "Offline AI text-to-speech",
    "longDescription": "Free, open-source, 100% offline AI text-to-speech desktop app powered by Kokoro-82M.",
    "resources": {
      "resources/onnxruntime/": "onnxruntime/",
      "resources/espeak/": "espeak/",
      "resources/models/": "models/",
      "resources/openapi.yaml": "openapi.yaml"
    }
  }
}
