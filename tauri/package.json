{
  "name": "out-loud-tauri",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Free, open-source, 100% offline AI text-to-speech desktop app powered by Kokoro-82M. Tauri + Vue + UnoCSS.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "stage": "node scripts/stage-resources.mjs",
    "sign": "node scripts/codesign-app.mjs",
    "dmg": "node scripts/make-dmg.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run stage && tauri build && npm run sign && npm run dmg",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^6.0.227",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.0",
    "@unocss/preset-icons": "^66.7.2",
    "@unocss/preset-wind4": "^66.7.2",
    "@unocss/transformer-directives": "^66.7.2",
    "@unocss/transformer-variant-group": "^66.7.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "onnxruntime-node": "1.20.1",
    "typescript": "~6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  }
}
